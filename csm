#!/bin/bash
# Container Stack Manager (CSM)
# A unified container stack management tool supporting multiple container runtimes
# Author: Drauku
# Date: 2025-06-10
# License: MIT

set -euo pipefail

# # CSM directories
# readonly CSM_ROOT_DIR="/srv/csm"
# readonly CSM_BACKUP_DIR="${CSM_ROOT_DIR}/backup"
# readonly CSM_COMMON_DIR="${CSM_ROOT_DIR}/common"
# readonly CSM_STACKS_DIR="${CSM_ROOT_DIR}/stacks"

# Load user configs, project configs, or default configs in that order
if [[ -f "${HOME}/.csm/config" ]]; then
    source "${HOME}/.csm/config"
elif [[ -f "${script_dir}/user.conf" ]]; then
    source "${script_dir}/user.conf"
else
    source "${script_dir}/default.conf"
fi

# Script directory
readonly script_dir
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source core utilities first
src1="${CSM_COMMON_DIR}/csm_functions.sh"
src2="${script_dir}/csm_functions.sh"
if [ -f "${src1}" ]; then
    source "${src1}"
elif [ -f "${src2}" ]; then
    source "${src2}"
else
    log ERROR "Failed to load configuration, file not found: ${src1} or ${src2}"
    exit 1
fi

# Function to show main help
show_main_help() {
    cat << 'EOF'
Container Stack Manager (CSM)

Usage: csm <command> [arguments]

Stack Lifecycle:
    c  | create <name>            Create a new stack
    m  | modify <name>            Edit stack configuration
    rm | remove <name>            Remove stack (keep data)
    dt | delete <name>            Delete stack and all data
    bu | backup <name>            Backup stack configuration

Stack Operations:
    u  | up | start <name>        Start a stack
    d  | dn | down | stop <name>  Stop a stack
    b  | bounce | recreate <name> Restart a stack
    r  | restart <name>           Restart a stack
    u  | update <name>            Update stack images

Information:
    l  | list                     List all stacks
    s  | status <name>            Show stack status
    v  | validate <name>          Validate stack configuration

Templates:
    t  | template <action>        Manage templates (list, add, remove, update)

Setup:
    -i | --install                Run initial installation setup

Options:
    -h | --help                   Show this help message
    -v | --version                Show version information

EOF
}

# Main function to handle command dispatching
main() {
    # Set default CSM_ROOT_DIR if not set
    export CSM_ROOT_DIR="${CSM_ROOT_DIR:-/srv/csm}"

    # Initialize configuration
    if ! load_config 2>/dev/null; then
        log ERROR "Failed to load configuration"
        exit 1
    fi

    # Validate configuration
    if ! validate_config; then
        log WARN "Configuration validation completed with warnings"
    fi

    local cmd="${1:-}" args=()
    shift || true

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h | --help)
                show_main_help
                exit 0
                ;;
            -v | --version)
                echo "CSM v1.0.0"
                exit 0
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    # Set remaining arguments
    set -- "${args[@]}"

    # Command dispatch
    case "$cmd" in
        c | create)
            create_stack "$@"
            ;;
        m | modify)
            modify_stack "$@"
            ;;
        rm | remove)
            remove_stack "$@"
            ;;
        dt | delete)
            delete_stack "$@"
            ;;
        bu | backup)
            backup_stack "$@"
            ;;
        u | up | start)
            up_stack "$@"
            ;;
        d | dn | down | stop)
            down_stack "$@"
            ;;
        b | bounce | rc | recreate)
            bounce_stack "$@"
            ;;
        r | rs | restart)
            restart_stack "$@"
            ;;
        ud | update)
            update_stack "$@"
            ;;
        l | ls | list)
            list_stacks
            ;;
        s | status)
            status_stack "$@"
            ;;
        v | validate)
            validate_stack "$@"
            ;;
        t | template)
            # shift
            manage_templates "$@"
            ;;
        cfg | config)
            manage_configs "$@"
            ;;
        i | install)
            install_csm
            ;;
        *)
            show_main_help
            exit 1
            ;;
    esac
}

# Execute main function with all arguments
main "$@"
